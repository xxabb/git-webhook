# Webhook Handler 环境变量配置
# 复制此文件为 .env 并填写实际值

# Webhook 签名验证密钥 (必填)
# Gogs/Gitea 中配置的 Secret 必须与此值一致
WEBHOOK_SECRET=your-secret-here

# HTTP 服务监听端口 (可选, 默认 8080)
WEBHOOK_PORT=8080

# 应用配置文件路径 (可选, 默认 conf.d/webhookd.yaml)
APP_CONFIG_FILE=conf.d/webhookd.yaml

# 日志目录路径 (可选, 默认 logs)
LOGS_DIR=logs

# 是否启用文件日志 (可选, 默认 false)
# 启用后日志同时输出到 stdout 和日志文件
ENABLE_FILE_LOGGING=false

# 启动时是否执行所有应用任务链 (可选, 默认 false)
# 设置为 true 或 1 会在程序启动时自动执行所有应用的任务链
RUN_ON_STARTUP=false
